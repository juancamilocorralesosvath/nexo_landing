rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() { return isSignedIn() && myRole() == 'admin'; }

    // Perfiles de usuario
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Cada quien crea su propio perfil y SIEMPRE como 'candidate'
      allow create: if isSignedIn()
                    && request.auth.uid == uid
                    && request.resource.data.role == 'candidate';
      // Nadie se auto-eleva a admin; solo un admin puede cambiar roles
      allow update: if isSignedIn() && (
                      (request.auth.uid == uid && request.resource.data.role == resource.data.role)
                      || isAdmin()
                    );
      allow delete: if isAdmin();
    }

    // Ofertas de empleo
    match /jobs/{jobId} {
      // Vacantes activas son públicas; el admin ve todas
      allow read: if resource.data.active == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Metadatos de documentos de candidatos
    match /documents/{docId} {
      allow read:   if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if false;
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Postulaciones
    match /applications/{appId} {
      allow read:   if isSignedIn() && (resource.data.candidateId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
                    && request.resource.data.candidateId == request.auth.uid
                    && request.resource.data.status == 'Recibida';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
